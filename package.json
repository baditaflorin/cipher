{
  "name": "cipher",
  "version": "0.1.0",
  "description": "Static, browser-only encrypted group chat with MLS, WebRTC mesh, local summaries, and no server-held group state.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Florin Badita",
  "homepage": "https://baditaflorin.github.io/cipher/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baditaflorin/cipher.git"
  },
  "bugs": {
    "url": "https://github.com/baditaflorin/cipher/issues"
  },
  "scripts": {
    "prebuild": "node scripts/write-build-info.mjs",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/postbuild.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "pages:preview": "bash scripts/serve-pages-preview.sh",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke.sh",
    "audit": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.2.0",
    "@tanstack/react-query": "^5.90.16",
    "idb": "^8.0.3",
    "libsodium-wrappers": "^0.8.4",
    "libsodium-wrappers": "^0.8.4",
    "lucide-react": "^0.562.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ts-mls": "^1.6.2",
    "yjs": "^13.6.30",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^25.0.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.25",
    "http-server": "^14.1.1",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.11",
    "vitest": "^4.0.17"
  }
}
